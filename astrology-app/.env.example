# ─────────────────────────────────────────────────────────────────────────────
# Cosmiq Astrology App — Frontend Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Node.js/Express backend server.
# In development: http://localhost:5000
# In production:  https://api.cosmiq.app  (or your deployed URL)
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign / verify JWT tokens on the client (if needed).
# The backend signs tokens; this is only used if the app verifies them locally.
EXPO_PUBLIC_JWT_SECRET=your_jwt_secret_here

# ── AI / Chat ─────────────────────────────────────────────────────────────────
# API key for the LLM powering the Cosmiq AI chat assistant (ChatScreen).
# The frontend calls the backend which proxies to the AI provider —
# keep the real provider key server-side only. This key authenticates
# the frontend → backend chat requests.
EXPO_PUBLIC_CHAT_API_KEY=your_chat_api_key_here

# ── Social Login ──────────────────────────────────────────────────────────────
# Google OAuth client ID (used by SocialLoginButtons for Google Sign-In).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Expo / EAS ────────────────────────────────────────────────────────────────
# EAS Project ID — found in app.json under "extra.eas.projectId".
# Required for EAS Build and OTA updates.
EXPO_PUBLIC_EAS_PROJECT_ID=0e37ac61-bcc8-4bcb-9e38-18e297f01b74

# ── App Config ────────────────────────────────────────────────────────────────
# Runtime environment flag. Values: "development" | "staging" | "production"
EXPO_PUBLIC_APP_ENV=development
